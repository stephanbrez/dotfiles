// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "restore_on_startup": "launchpad",
    "outline_panel": {
        "dock": "left",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "git_panel": {
        "dock": "left",
    },
    "agent_servers": {
        "codex-acp": {
            "type": "registry",
        },
        "gemini": {
            "type": "registry",
        },
        "claude-acp": {
            "type": "registry",
        },
        "mistral-vibe": {
            "type": "registry",
        },
        "opencode": {
            "type": "registry",
        },
    },
    "edit_predictions": {
        "mode": "subtle",
    },
    "ssh_connections": [
        {
            "host": "populus.birchcrown.com",
            "projects": [
                {
                    "paths": [
                        "/home/stephan/.local/src/3d-reconstruction-from-monocular-multi-food-images",
                    ],
                },
                {
                    "paths": ["~/.local/src/pytorch_tuts"],
                },
            ],
        },
    ],
    // ========== AI ==========
    "agent_ui_font_size": 12,
    "agent": {
        "tool_permissions": {
            "tools": {
                "terminal": {
                    "always_allow": [
                        {
                            "pattern": "^uv\\s+run(\\s|$)",
                        },
                    ],
                },
            },
        },
        "use_modifier_to_send": true,
        "dock": "left",
        "inline_assistant_model": {
            "provider": "google",
            "model": "gemini-3-flash-preview",
        },
        "default_profile": "write",
        "default_model": {
            "enable_thinking": false,
            "provider": "openai",
            "model": "gpt-5.5",
        },
    },
    "language_models": {
        "ollama": {
            "api_url": "http://192.168.20.10:11434",
            "available_models": [],
        },
    },
    "telemetry": {
        "metrics": false,
    },
    "vim_mode": true,
    "which_key": {
        "enabled": true,
        "delay_ms": 20,
    },
    "vim": {
        "toggle_relative_line_numbers": true,
        "custom_digraphs": {
            "fz": "",
        },
    },
    "autosave": "on_focus_change",
    "tab_size": 4,
    "preferred_line_length": 80,
    "soft_wrap": "bounded",
    // ========== Git ==========
    "git": {
        "inline_blame": {
            "enabled": false,
            "min_column": 80,
        },
    },
    // ========== LSP ==========
    "languages": {
        "Python": {
            // "language_servers": ["pyright", "pylsp"],
        },
        "Markdown": {},
    },
    // ========== Terminal ==========
    "terminal": {
        "font_family": "FiraMono Nerd Font",
    },
    // ========== UI ==========
    "active_pane_modifiers": {
        "border_size": 6.0,
        "inactive_opacity": 0.9,
    },
    "tabs": {
        "close_position": "right",
        "file_icons": true,
        "git_status": false,
        "activate_on_close": "history",
        "show_close_button": "hover",
        "show_diagnostics": "off",
    },
    "indent_guides": {
        "enabled": true,
        "line_width": 1,
        "active_line_width": 2,
        "coloring": "indent_aware",
        "background_coloring": "indent_aware",
    },
    "wrap_guides": [80],
    "show_wrap_guides": true,
    "ui_font_size": 12,
    "ui_font_features": {
        "calt": true,
    },
    "buffer_font_family": "FiraMono Nerd Font",
    "buffer_font_size": 12,
    "buffer_font_weight": 400,
    "theme": {
        "mode": "light",
        "light": "Kanso Pearl",
        "dark": "Tokyo Night Storm",
    },
    "icon_theme": "Colored Zed Icons Theme Light",
    "project_panel": {
        "dock": "left",
        "entry_spacing": "standard",
    },
    "diagnostics": {
        "include_warnings": true,
        "inline": {
            "enabled": true,
            "update_debounce_ms": 150,
            "padding": 4,
            "min_column": 80,
            "max_severity": null,
        },
    },
    "inlay_hints": {
        "enabled": false,
        "show_type_hints": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_background": false,
        "edit_debounce_ms": 700,
        "scroll_debounce_ms": 50,
        "toggle_on_modifiers_press": null,
    },
}
