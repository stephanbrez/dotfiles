#!/bin/bash

#  ‚Ėą‚Ėą‚Ėď ‚Ėą‚Ėą‚Ėą‚ĖĄ    ‚Ėą   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėď ‚ĖĄ‚ĖĄ‚ĖĄ       ‚Ėą‚Ėą‚Ėď     ‚Ėą‚Ėą‚Ėď    ‚Ėď‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚ĖÄ‚Ėą‚Ėą‚Ėą
# ‚Ėď‚Ėą‚Ėą‚Ėí ‚Ėą‚Ėą ‚ĖÄ‚Ėą   ‚Ėą ‚Ėí‚Ėą‚Ėą    ‚Ėí ‚Ėď  ‚Ėą‚Ėą‚Ėí ‚Ėď‚Ėí‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĄ    ‚Ėď‚Ėą‚Ėą‚Ėí    ‚Ėď‚Ėą‚Ėą‚Ėí    ‚Ėď‚Ėą   ‚ĖÄ ‚Ėď‚Ėą‚Ėą ‚Ėí ‚Ėą‚Ėą‚Ėí
# ‚Ėí‚Ėą‚Ėą‚Ėí‚Ėď‚Ėą‚Ėą  ‚ĖÄ‚Ėą ‚Ėą‚Ėą‚Ėí‚ĖĎ ‚Ėď‚Ėą‚Ėą‚ĖĄ   ‚Ėí ‚Ėď‚Ėą‚Ėą‚ĖĎ ‚Ėí‚ĖĎ‚Ėí‚Ėą‚Ėą  ‚ĖÄ‚Ėą‚ĖĄ  ‚Ėí‚Ėą‚Ėą‚ĖĎ    ‚Ėí‚Ėą‚Ėą‚ĖĎ    ‚Ėí‚Ėą‚Ėą‚Ėą   ‚Ėď‚Ėą‚Ėą ‚ĖĎ‚ĖĄ‚Ėą ‚Ėí
# ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėď‚Ėą‚Ėą‚Ėí  ‚Ėź‚ĖĆ‚Ėą‚Ėą‚Ėí  ‚Ėí   ‚Ėą‚Ėą‚Ėí‚ĖĎ ‚Ėď‚Ėą‚Ėą‚Ėď ‚ĖĎ ‚ĖĎ‚Ėą‚Ėą‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚Ėą ‚Ėí‚Ėą‚Ėą‚ĖĎ    ‚Ėí‚Ėą‚Ėą‚ĖĎ    ‚Ėí‚Ėď‚Ėą  ‚ĖĄ ‚Ėí‚Ėą‚Ėą‚ĖÄ‚ĖÄ‚Ėą‚ĖĄ
# ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėí‚Ėą‚Ėą‚ĖĎ   ‚Ėď‚Ėą‚Ėą‚ĖĎ‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí‚Ėí  ‚Ėí‚Ėą‚Ėą‚Ėí ‚ĖĎ  ‚Ėď‚Ėą   ‚Ėď‚Ėą‚Ėą‚Ėí‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí‚ĖĎ‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí‚ĖĎ‚Ėą‚Ėą‚Ėď ‚Ėí‚Ėą‚Ėą‚Ėí
# ‚ĖĎ‚Ėď  ‚ĖĎ ‚Ėí‚ĖĎ   ‚Ėí ‚Ėí ‚Ėí ‚Ėí‚Ėď‚Ėí ‚Ėí ‚ĖĎ  ‚Ėí ‚ĖĎ‚ĖĎ    ‚Ėí‚Ėí   ‚Ėď‚Ėí‚Ėą‚ĖĎ‚ĖĎ ‚Ėí‚ĖĎ‚Ėď  ‚ĖĎ‚ĖĎ ‚Ėí‚ĖĎ‚Ėď  ‚ĖĎ‚ĖĎ‚ĖĎ ‚Ėí‚ĖĎ ‚ĖĎ‚ĖĎ ‚Ėí‚Ėď ‚ĖĎ‚Ėí‚Ėď‚ĖĎ
#  ‚Ėí ‚ĖĎ‚ĖĎ ‚ĖĎ‚ĖĎ   ‚ĖĎ ‚Ėí‚ĖĎ‚ĖĎ ‚ĖĎ‚Ėí  ‚ĖĎ ‚ĖĎ    ‚ĖĎ      ‚Ėí   ‚Ėí‚Ėí ‚ĖĎ‚ĖĎ ‚ĖĎ ‚Ėí  ‚ĖĎ‚ĖĎ ‚ĖĎ ‚Ėí  ‚ĖĎ ‚ĖĎ ‚ĖĎ  ‚ĖĎ  ‚ĖĎ‚Ėí ‚ĖĎ ‚Ėí‚ĖĎ
#  ‚Ėí ‚ĖĎ   ‚ĖĎ   ‚ĖĎ ‚ĖĎ ‚ĖĎ  ‚ĖĎ  ‚ĖĎ    ‚ĖĎ        ‚ĖĎ   ‚Ėí     ‚ĖĎ ‚ĖĎ     ‚ĖĎ ‚ĖĎ      ‚ĖĎ     ‚ĖĎ‚ĖĎ   ‚ĖĎ
#  ‚ĖĎ           ‚ĖĎ       ‚ĖĎ                 ‚ĖĎ  ‚ĖĎ    ‚ĖĎ  ‚ĖĎ    ‚ĖĎ  ‚ĖĎ   ‚ĖĎ  ‚ĖĎ   ‚ĖĎ

# ‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó
# ‚ēĎ  ‚ĖĎ‚Ėą‚ĖĄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖÄ‚ĖĎ‚ĖÄ‚Ėą‚ĖÄ‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖÄ‚ĖĎ‚Ėą‚ĖĎ‚Ėą  ‚ēĎ
# ‚ēĎ  ‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚Ėą‚ĖĎ  ‚ēĎ
# ‚ēĎ  ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ  ‚ēĎ
# ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
# Automate the installation of dotfiles and tools
# Distro independent - Also works for Mac
#
# See README.md for documentation on adding new installers
#

#########################################
# Script setup                          #
#########################################
# ‚ĒÄ‚ĒÄ‚ĒÄ Detect user and directories ‚ĒÄ‚ĒÄ‚ĒÄ
# ‚Ěó IMPORTANT: This script should be run with sudo, not as raw root
# Running with sudo preserves the original user context

# Check if running as root
if [ "$EUID" -ne 0 ]; then
	echo "Error: This script must be run with sudo"
	echo "Usage: sudo ./setup"
	exit 1
fi

# Get the real user (the one who ran sudo)
if [ -n "$SUDO_USER" ]; then
	# Normal case: script run with sudo
	me="$SUDO_USER"
	myhome=$(eval echo "~$SUDO_USER")
else
	# Edge case: Running as raw root (Docker, CI, or bad practice)
	# Check if we're in a container or CI environment
	if [ -f /.dockerenv ] || [ -n "$CI" ]; then
		# Allow running as root in containers/CI
		me="root"
		myhome="/root"
	else
		# Not in container - this is bad practice
		echo "Error: Running as raw root is not supported"
		echo "Please run with sudo as a regular user: sudo ./setup"
		exit 1
	fi
fi

basedir="$myhome/.dotfiles"
bindir="$myhome/.local/bin"
repourl="https://github.com/stephanbrez/dotfiles.git"
ARCH=$(uname -m)

# Run commands as the actual user (not root)
ASME="sudo -u $me"

# ‚ĒÄ‚ĒÄ‚ĒÄ Architecture mapping for different package formats ‚ĒÄ‚ĒÄ‚ĒÄ
# uname -m returns: x86_64, aarch64, armv7l, etc.
# dpkg uses: amd64, arm64, armhf, etc.
# GitHub releases vary: x86_64, arm64, aarch64, etc.
case "$ARCH" in
x86_64) ARCH_DEB="amd64" ARCH_GH="x86_64" ;;
aarch64) ARCH_DEB="arm64" ARCH_GH="arm64" ;;
armv7l) ARCH_DEB="armhf" ARCH_GH="armv7" ;;
*) ARCH_DEB="$ARCH" ARCH_GH="$ARCH" ;;
esac
# ======== end user options ======== #

# Initialize modes
verbose_mode=false
dry_run=false
auto_yes=false
install_mode="" # Will be set based on distro or -f flag

# Parse command-line arguments
show_help() {
	cat <<-EOF
		Usage: sudo $0 [OPTIONS]

		‚Ěó This script must be run with sudo to install system packages.

		Options:
		  -v, --verbose    Verbose mode - show detailed output
		  -n, --dry-run    Dry-run mode - preview commands without executing
		  -y, --yes        Auto-yes mode - skip interactive prompts (for CI/testing)
		  -f, --full       Full install mode - force full package installation (overrides minimal)
		  -h, --help       Show this help message

		Installation Modes:
		  - Ubuntu: Minimal mode by default (use -f/--full for full install)
		  - Debian/Other: Full mode always

		Examples:
		  sudo $0 --verbose           Run with verbose output
		  sudo $0 --dry-run           Preview what would be done (no changes made)
		  sudo $0 -v --dry-run        Verbose dry-run
		  sudo $0 --yes               Run non-interactively (auto-accept prompts)
		  sudo $0 --full              Force full installation on Ubuntu
		  sudo $0 --dry-run --yes     Dry-run without prompts (for testing)
	EOF
	exit 0
}

while getopts "vnyfh-:" option; do
	case $option in
	v) verbose_mode=true ;;
	n) dry_run=true ;;
	y) auto_yes=true ;;
	f) install_mode="full" ;;
	h) show_help ;;
	-)
		# Handle long options
		case "${OPTARG}" in
		verbose) verbose_mode=true ;;
		dry-run) dry_run=true ;;
		yes) auto_yes=true ;;
		full) install_mode="full" ;;
		help) show_help ;;
		*)
			echo "Unknown option --${OPTARG}"
			echo "Usage: $0 [-v|--verbose] [-n|--dry-run] [-y|--yes] [-f|--full] [-h|--help]"
			exit 1
			;;
		esac
		;;
	*)
		echo "Usage: $0 [-v|--verbose] [-n|--dry-run] [-y|--yes] [-f|--full] [-h|--help]"
		exit 1
		;;
	esac
done

if $dry_run; then
	echo "‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź"
	echo "  DRY-RUN MODE - No changes will be made"
	echo "‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź"
fi
echo "Verbose mode is $verbose_mode"

# ======== helper functions ======== #
function _echo() { printf "\n‚ēď‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ %s \n‚ēô‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ ‚ĒÄ ‚ĒÄ \n" "$1"; }
function user() { printf "\r  [ \033[33m??\033[0m ] %s" "$1"; }
function fail() {
	printf "\r\033[2K  [ \033[01;31mFAIL\033[0m ] %s\n" "$1"
	echo ''
	exit
}

# ‚ĒÄ‚ĒÄ‚ĒÄ Dry-run helper functions ‚ĒÄ‚ĒÄ‚ĒÄ
# Print what would be done in dry-run mode
dry_print() {
	printf "  [ \033[36mDRY\033[0m ] %s\n" "$1"
}

# Check if we should skip execution (dry-run mode)
# Usage: if should_run; then actual_command; fi
# Or:    should_run && actual_command
should_run() {
	! $dry_run
}

# Run a package-manager command as the appropriate user.
# Homebrew refuses to run as root, so on macOS delegate to $ASME (the
# original sudo user). Linux package managers (apt, dnf, pacman, etc.)
# require root, so run directly ‚ÄĒ setup runs under sudo.
# Usage: pkg_run $pkgmgr $pkginstall <packages...>
pkg_run() {
	if [[ "$pkgmgr" == "brew" ]]; then
		$ASME "$@"
	else
		"$@"
	fi
}

log_message() {
	# Function to format and print messages based on the type with optional override to force display (ignore verbose)
	# Usage: log_message "str:MSGTYPE" "str:Message" "boolean:force display"
	local message_type=$1
	local message=$2
	local force=${3:-false}
	local timestamp
	timestamp=$(date +"%Y-%m-%d %H:%M:%S")

	if $verbose_mode || $force; then
		case $message_type in
		DEBUG) printf "  [ \033[36mDebug\033[0m ][%s] %s\n" "$timestamp" "$message" ;;
		INFO) printf "[ \033[34m>>\033[0m ] %s\n" "$message" ;;
		WARNING) printf "[\033[1;31m !!! \033[0m][%s] %s\n" "$timestamp" "$message" ;;
		SUCCESS) printf "\033[2K  [ \033[32mOK\033[0m ] %s\n" "$message" ;;
		*) printf "[UNKNOWN][%s] %s\n" "$timestamp" "$message" ;; # Fallback for unknown message types
		esac
	fi
}

function linux_package() {
	if [ -x "$(command -v apk)" ]; then
		pkgmgr="apk"
		pkginstall="add --no-cache"
		pkgupdate="update"
	elif [ -x "$(command -v apt)" ]; then
		pkgmgr="apt"
		pkginstall="install -y"
		pkgupdate="update"
		# ‚ĒÄ‚ĒÄ‚ĒÄ Detect Debian vs Ubuntu ‚ĒÄ‚ĒÄ‚ĒÄ
		if [ -f /etc/os-release ]; then
			DISTRO_ID=$(grep "^ID=" /etc/os-release | cut -d'=' -f2 | tr -d '"')
			DISTRO_VERSION=$(grep "^VERSION_ID=" /etc/os-release | cut -d'=' -f2 | tr -d '"')
		else
			DISTRO_ID="debian"
			DISTRO_VERSION="unknown"
		fi
	elif [ -x "$(command -v dnf)" ]; then
		pkgmgr="dnf"
		pkginstall="install -y"
		pkgupdate="update"
	elif [ -x "$(command -v pacman)" ]; then
		pkgmgr="pacman"
		pkginstall="-S"
		pkgupdate="-Syu"
	elif [ -x "$(command -v zypper)" ]; then
		pkgmgr="zypper"
		pkginstall="install"
		pkgupdate="refresh && zypper update"
	else
		fail "Package manager not found. You must manually install packages."
	fi
}
# for avoiding eval some day
# pkgcommands[0] = "$pkgmgr $pkginstall"
# pkgcommands[1] = "$pkgmgr $pkgupdate"

# ‚ĒÄ‚ĒÄ‚ĒÄ Source third-party installers ‚ĒÄ‚ĒÄ‚ĒÄ
for installer in "$basedir"/installers/*.sh; do
	[ -f "$installer" ] && source "$installer"
done

# ======== sanity check ======== #
log_message "INFO" "Detected user: $me (home: $myhome)" "true"
log_message "INFO" "Setting up dotfiles in '$basedir'" "true"
if $auto_yes; then
	log_message "INFO" "Auto-yes mode enabled, continuing..." "true"
else
	while true; do
		user "Do you want to continue? (y/n): "
		read -r -n1 yn
		echo # Move to a new line after reading input
		case $yn in
		y | Y)
			log_message "INFO" "Continuing..." "true"
			break
			;;
		n | N) fail "Exiting." ;;
		*) log_message "WARNING" "Invalid response. Please enter 'y' or 'n'." "true" ;;
		esac
	done
fi

_echo "creating directories"
if should_run; then
	$ASME mkdir -p \
		"$myhome"/.{config,local} \
		"$myhome"/.local/{bin,cache,lib,share,src,state}
	# Symlink ~/Documents ‚Üí ~/.local/docs (Linux only). On macOS, Documents is
	# a native directory with TCC privacy protections and may not exist on a
	# fresh account; skip to avoid dangling symlinks and permission friction.
	if [[ "$OSTYPE" != "darwin"* ]] && [[ -d "$myhome/Documents" ]]; then
		$ASME ln -sfn "$myhome"/Documents "$myhome"/.local/docs
	fi
else
	dry_print "Would create ~/.config, ~/.local and subdirectories"
	if [[ "$OSTYPE" != "darwin"* ]]; then
		dry_print "Would symlink ~/Documents to ~/.local/docs"
	fi
fi

#########################################
# Install Packages                      #
#########################################

# ‚ēź‚ēź‚ēź‚ēź‚ēź Bootstrap Python Environment ‚ēź‚ēź‚ēź‚ēź‚ēź
# Install python3 and PyYAML before parsing packages.yaml
# CRITICAL: This must run FIRST on fresh machines
bootstrap_python() {
	_echo "bootstrapping Python environment for package configuration"

	# Determine the correct PyYAML package name for this distro
	local pyyaml_pkg=""
	case "$pkgmgr" in
	apt*)
		pyyaml_pkg="python3-yaml"
		;;
	dnf*)
		pyyaml_pkg="python3-pyyaml"
		;;
	pacman*)
		pyyaml_pkg="python-yaml"
		;;
	brew*)
		pyyaml_pkg=""
		;;
	*)
		log_message "WARNING" "Unknown package manager, cannot install PyYAML" "true"
		return 1
		;;
	esac

	# Install python3 and PyYAML from system packages.
	# Split the check: python3 may not exist (fresh macOS without Xcode CLT),
	# and PyYAML may be missing even if python3 is present. Each case gets a
	# distinct install command and log message.
	if ! command -v python3 &>/dev/null; then
		log_message "INFO" "python3 not found, installing python3..." "true"
		if should_run; then
			if [[ "$pkgmgr" == "brew" ]]; then
				pkg_run $pkgmgr $pkginstall python3
			else
				pkg_run $pkgmgr $pkginstall python3 $pyyaml_pkg
			fi
		else
			dry_print "Would install: python3${pyyaml_pkg:+ $pyyaml_pkg}"
		fi
	fi

	if ! python3 -c "import yaml" 2>/dev/null; then
		log_message "INFO" "PyYAML missing, installing..." "true"
		if should_run; then
			if [[ "$pkgmgr" == "brew" ]]; then
				[[ -x "$(brew --prefix)/bin/python3" ]] || pkg_run $pkgmgr $pkginstall python3
				$ASME "$(brew --prefix)/bin/python3" -m pip install --break-system-packages pyyaml
			else
				pkg_run $pkgmgr $pkginstall $pyyaml_pkg
			fi
		else
			dry_print "Would install: ${pyyaml_pkg:-pyyaml via pip}"
		fi
	fi

	# Verify PyYAML is available
	if python3 -c "import yaml" 2>/dev/null; then
		log_message "SUCCESS" "Python environment ready"
		return 0
	else
		log_message "WARNING" "PyYAML not available, falling back to inline definitions" "true"
		return 1
	fi
}

# ‚ēź‚ēź‚ēź‚ēź‚ēź YAML Parser ‚ēź‚ēź‚ēź‚ēź‚ēź
# Parse packages.yaml and export bash arrays for package installation
parse_packages_yaml() {
	local yaml_file="$1"
	local distro="$2"
	local mode="$3"

	if [ ! -f "$yaml_file" ]; then
		log_message "WARNING" "packages.yaml not found, using inline definitions" "true"
		return 1
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ Check if python3 and PyYAML are available ‚ĒÄ‚ĒÄ‚ĒÄ
	if ! python3 -c "import yaml" 2>/dev/null; then
		log_message "WARNING" "Python3 or PyYAML not available, using fallback" "true"
		return 1
	fi

	# Use Python to parse YAML and output bash variable assignments
	local python_output
	python_output=$(
		python3 <<EOF
import yaml
import sys

try:
    with open('$yaml_file', 'r') as f:
        config = yaml.safe_load(f)

    # Get distro-specific config (top-level may have skip_common)
    distro_top = config.get('$distro', {})
    skip_common = distro_top.get('skip_common', False)

    # Get common packages (skipped if distro sets skip_common: true)
    common_pkgs = [] if skip_common else config.get('common', {}).get('distro_packages', [])

    # Get mode-specific config
    distro_config = distro_top.get('$mode', {})
    distro_pkgs = distro_config.get('distro_packages', [])

    # Combine and output
    all_pkgs = common_pkgs + distro_pkgs

    # Symlink-fix / post-install flags: distro packages that need a follow-up
    # after package installation. Lets setup guard the follow-up on actual
    # package inclusion, abstracting away distro-specific package names.
    #   bat/fd-find: binary renamed on apt (batcat/fdfind) ‚Üí symlink fix
    #   tmux: TPM plugin install runs after tmux.conf is stowed
    if "bat" in all_pkgs:
        print("PKG_BAT=true")
    if "fd-find" in all_pkgs or "fd" in all_pkgs:
        print("PKG_FD=true")
    if "tmux" in all_pkgs:
        print("PKG_TMUX=true")

    print(f"PKG_DISTRO_PACKAGES=({' '.join(all_pkgs)})")

    # Export third-party flags
    third_party = distro_config.get('third_party', {})
    skip_third_party = distro_config.get('skip_third_party', False)

    if skip_third_party:
        print("SKIP_THIRD_PARTY=true")
        print("PKG_THIRD_PARTY=()")
    else:
        # PKG_THIRD_PARTY keeps canonical hyphen names from YAML; bash
        # identifiers (function names, INSTALL_<NAME> env vars) convert
        # hyphens to underscores at their construction sites.
        enabled_names = [n for n, on in third_party.items() if on]
        print(f"PKG_THIRD_PARTY=({' '.join(enabled_names)})")
        for name, enabled in third_party.items():
            if enabled:
                print(f"INSTALL_{name.replace('-', '_').upper()}=true")

    # Export pipx packages
    pipx_pkgs = distro_config.get('pipx_packages', [])
    if pipx_pkgs:
        print(f"PKG_PIPX_PACKAGES=({' '.join(pipx_pkgs)})")

    # Export npm packages
    npm_pkgs = config.get('common', {}).get('npm_packages', [])
    if npm_pkgs:
        print(f"PKG_NPM_PACKAGES=({' '.join(npm_pkgs)})")

except Exception as e:
    print(f"echo 'Error parsing YAML: {e}' >&2", file=sys.stderr)
    sys.exit(1)
EOF
	)
	local python_exit=$?

	if [ $python_exit -ne 0 ] || [ -z "$python_output" ]; then
		log_message "WARNING" "Failed to parse packages.yaml" "true"
		return 1
	fi

	log_message "INFO" "YAML parsed output: $python_output" "true"
	eval "$python_output"
	return 0
}

# ‚ēź‚ēź‚ēź‚ēź‚ēź Third-Party Package Installers ‚ēź‚ēź‚ēź‚ēź‚ēź
# Installer functions are sourced from installers/*.sh

install_pipx_packages() {
	_echo "setting up python + pipx packages"
	if should_run; then
		$ASME pipx ensurepath # add bin path to bash - aka $bindir
		# Install pipx packages from YAML config
		for pkg in "${PKG_PIPX_PACKAGES[@]}"; do
			$ASME pipx install "$pkg"
		done
		# install python neovim after neovim because debian will install old neovim
		# (not needed on macOS ‚ÄĒ neovim via brew is current, pynvim via pip)
		if [[ "$pkgmgr" != "brew" ]]; then
			eval "$pkgmgr $pkginstall python3-neovim"
		fi
	else
		dry_print "Would configure pipx and install: ${PKG_PIPX_PACKAGES[*]} python3-neovim"
	fi
}

install_npm_packages() {
	_echo "installing npm global packages"
	if should_run; then
		for pkg in "${PKG_NPM_PACKAGES[@]}"; do
			$ASME npm install -g "$pkg"
		done
	else
		dry_print "Would npm install -g: ${PKG_NPM_PACKAGES[*]}"
	fi
}

function install_packages() {
	_echo "configuring package manager"
	case "$OSTYPE" in
	darwin*)
		bootstrap_brew
		pkgmgr="brew"
		pkginstall="install"
		pkgupdate="update"
		DISTRO_ID="macos"
		;;
	linux*)
		linux_package
		;;
	bsd*)
		# BSD support placeholder
		;;
	msys*)
		echo "WINDOWS"
		;;
	cygwin*)
		echo "ALSO WINDOWS"
		;;
	win32*)
		echo "WINDOWS"
		;;
	*)
		fail "unknown: $OSTYPE"
		;;
	esac

	_echo "updating package manager"
	if should_run; then
		pkg_run "$pkgmgr" "$pkgupdate"
	else
		dry_print "Would run: $pkgmgr $pkgupdate"
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ Bootstrap Python + PyYAML (CRITICAL: Must be first!) ‚ĒÄ‚ĒÄ‚ĒÄ
	bootstrap_python

	# ‚ĒÄ‚ĒÄ‚ĒÄ Determine installation mode ‚ĒÄ‚ĒÄ‚ĒÄ
	if [ -z "$install_mode" ]; then
		# Auto-detect based on distro
		if [[ "$DISTRO_ID" == "ubuntu" ]]; then
			install_mode="minimal"
			log_message "INFO" "Ubuntu detected: using minimal installation mode" "true"
		else
			install_mode="full"
			log_message "INFO" "Using full installation mode" "true"
		fi
	else
		log_message "INFO" "Installation mode forced to: $install_mode" "true"
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ Load package configuration ‚ĒÄ‚ĒÄ‚ĒÄ
	packages_yaml="$basedir/packages.yaml"
	USE_YAML_CONFIG=false
	if parse_packages_yaml "$packages_yaml" "$DISTRO_ID" "$install_mode"; then
		log_message "SUCCESS" "Loaded package configuration from YAML"
		USE_YAML_CONFIG=true
	else
		log_message "WARNING" "Using inline package definitions (fallback)" "true"
		USE_YAML_CONFIG=false
	fi

	# install all the things \o/
	_echo "installing packages"

	if [ "$USE_YAML_CONFIG" = true ]; then
		# ‚ĒÄ‚ĒÄ‚ĒÄ Install packages from YAML configuration ‚ĒÄ‚ĒÄ‚ĒÄ
		log_message "INFO" "Installing packages from YAML config..." "true"
		if should_run; then
			pkg_run $pkgmgr $pkginstall "${PKG_DISTRO_PACKAGES[@]}"
		else
			dry_print "Would install distro packages: ${PKG_DISTRO_PACKAGES[*]}"
		fi
	else
		# ‚ĒÄ‚ĒÄ‚ĒÄ Fallback: Install packages from installers/packages-fallback.sh ‚ĒÄ‚ĒÄ‚ĒÄ
		install_fallback_packages
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ apt keyring directory (Debian/Ubuntu only) ‚ĒÄ‚ĒÄ‚ĒÄ
	if [[ "$pkgmgr" == "apt" ]]; then
		if should_run; then
			mkdir -p /etc/apt/keyrings
		else
			dry_print "Would create /etc/apt/keyrings"
		fi
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ flatpak repo (all Linux distros, not macOS) ‚ĒÄ‚ĒÄ‚ĒÄ
	if [[ "$OSTYPE" == "linux"* ]]; then
		if should_run; then
			flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
		else
			dry_print "Would add flatpak flathub repo"
		fi
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ Third-party installations ‚ĒÄ‚ĒÄ‚ĒÄ
	# Skip all third-party if in minimal mode
	if [[ "$SKIP_THIRD_PARTY" == "true" ]]; then
		log_message "INFO" "Skipping third-party installations (minimal mode)" "true"
		return
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ Install third-party packages via auto-discovery ‚ĒÄ‚ĒÄ‚ĒÄ
	# Each YAML third_party key <name> maps to install_<name>() defined in
	# installers/<name>.sh. YAML keys use canonical hyphens (matching package-
	# manager conventions); bash function names convert hyphens to underscores.
	log_message "INFO" "Third-party installers enabled: ${PKG_THIRD_PARTY[*]:-(none)}" "true"
	for name in "${PKG_THIRD_PARTY[@]}"; do
		local func="install_${name//-/_}"
		if declare -f "$func" >/dev/null 2>&1; then
			"$func"
		else
			log_message "WARNING" "No installer function '$func' for '$name' ‚ÄĒ skipping" "true"
		fi
	done

	# ‚ĒÄ‚ĒÄ‚ĒÄ Install pipx packages if configured ‚ĒÄ‚ĒÄ‚ĒÄ
	if [ -n "${PKG_PIPX_PACKAGES[*]}" ]; then
		install_pipx_packages
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ Install npm packages if configured ‚ĒÄ‚ĒÄ‚ĒÄ
	if [ -n "${PKG_NPM_PACKAGES[*]}" ]; then
		install_nodejs
		install_npm_packages
	fi

	# ‚ĒÄ‚ĒÄ‚ĒÄ Distro binary symlinks (only if the package is configured) ‚ĒÄ‚ĒÄ‚ĒÄ
	# PKG_BAT/PKG_FD are emitted by the YAML parser (or set by the fallback
	# path); they abstract away the distro-specific package name (fd-find vs
	# fd) so setup only acts on actual inclusion. The installers themselves
	# additionally guard on $pkgmgr == apt since the rename is apt-specific.
	[[ "${PKG_BAT:-}" == "true" ]] && install_bat
	[[ "${PKG_FD:-}" == "true" ]] && install_fd

	# ‚ĒÄ‚ĒÄ‚ĒÄ Fun stuff (always install) ‚ĒÄ‚ĒÄ‚ĒÄ
	# install_figlet_fonts
}

if $auto_yes; then
	log_message "INFO" "Auto-yes mode: installing packages..." "true"
	install_packages
else
	while true; do
		user "Do you want to install packages? (y/n): "
		read -r -n1 yn
		echo # Move to a new line after reading input
		case $yn in
		[Yy]*)
			log_message "INFO" "Continuing with package install..." "true"
			install_packages
			break
			;;
		[Nn]*)
			log_message "INFO" "Skipping package install." "true"
			break
			;;
		*) log_message "WARNING" "Invalid response. Please enter 'y' or 'n'." "true" ;;
		esac
	done
fi

#########################################
# Setup                                 #
#########################################

# ======== setup dotfiles ======== #
# ‚Ěó IMPORTANT: User must clone the repo before running setup
# Usage: git clone https://github.com/stephanbrez/dotfiles.git ~/.dotfiles
#        sudo ~/.dotfiles/setup
_echo "setting up dotfiles"
if should_run; then
	if [ -d "$basedir" ]; then
		log_message "INFO" "Symlinking dotfiles with stow..."
		if $auto_yes; then
			"$basedir/bin/.local/bin/stowaway-check" -y "$basedir" "$myhome"
		else
			"$basedir/bin/.local/bin/stowaway-check" "$basedir" "$myhome"
		fi
	else
		fail "Dotfiles not found at $basedir. Please clone the repo first:\n  git clone $repourl $basedir"
	fi
else
	dry_print "Would run stowaway-check to symlink dotfiles"
fi

# ======== restow no-folding helper ======== #
# claude-code & codex share their target dirs (~/.local/share/<pkg>) with
# runtime content (sessions, caches, skillshare-managed skills). Stow's
# default folding would collapse those shared dirs into a single symlink to
# the repo, so the apps would write runtime files into the repo. Pre-create
# the runtime dirs and restow with --no-folding so stow symlinks only
# individual files, keeping runtime dirs real.
restow_no_folding() {
	local pkg="$1"
	local pkg_path="$basedir/$pkg"

	if [ ! -d "$pkg_path" ]; then
		log_message "WARNING" "Skipping --no-folding restow: $pkg_path not found" "true"
		return 0
	fi

	log_message "INFO" "Restowing $pkg with --no-folding..." "true"
	if $ASME stow -R -d "$basedir" -t "$myhome" --no-folding "$pkg"; then
		log_message "SUCCESS" "$pkg restowed with --no-folding"
	else
		log_message "WARNING" "Failed to restow $pkg with --no-folding ‚ÄĒ resolve conflicts (e.g. real files in target not in repo), then re-run" "true"
	fi
}

# ======== setup claude-code ======== #
# Gate on the stow package existing in the repo ‚ÄĒ skip entirely (no banner,
# no empty runtime dir) if the user doesn't have the package.
if [[ -d "$basedir/claude-code" ]]; then
	_echo "setting up claude-code"
	if should_run; then
		$ASME mkdir -p "$myhome/.local/share/claude-code"
		restow_no_folding "claude-code"
	else
		dry_print "Would create ~/.local/share/claude-code and restow with --no-folding"
	fi
fi

# ======== setup codex ======== #
if [[ -d "$basedir/codex" ]]; then
	_echo "setting up codex"
	if should_run; then
		$ASME mkdir -p "$myhome/.local/share/codex"
		restow_no_folding "codex"
	else
		dry_print "Would create ~/.local/share/codex and restow with --no-folding"
	fi
fi

# ======== setup git ======== #
_echo "setting up git"
if should_run; then
	if ! $auto_yes; then
		# Git config name
		echo "Please enter your FULL NAME for Git configuration:"
		read -r git_user_name

		# Git config email
		echo "Please enter your EMAIL for Git configuration:"
		read -r git_user_email

		# Set git credentials
		git config --global user.name "$git_user_name"
		git config --global user.email "$git_user_email"
		log_message "SUCCESS" "gitconfig"
	else
		log_message "INFO" "Skipping git config in auto-yes mode"
	fi
else
	dry_print "Would prompt for git user.name and user.email"
fi

# ======== setup tmux ======== #
# PKG_TMUX is emitted by the YAML parser (or set by the fallback path) when
# tmux is in the distro's package list. The installer itself guards on
# command -v tmux (package may not have installed) and is idempotent (skips
# if TPM is already cloned). Replaces the inline block that ran unconditionally
# and called fail() ‚ÄĒ which aborted the entire script ‚ÄĒ when tmux wasn't
# installed (e.g. macOS, where tmux is commented out in packages.yaml).
[[ "${PKG_TMUX:-}" == "true" ]] && install_tmux

# ======== zsh ======== #
# macOS ships zsh as the default shell since Catalina (10.15), so chsh is
# unnecessary there. On Linux, change the default shell if zsh is installed.
if [[ "$OSTYPE" != "darwin"* ]]; then
	_echo "setting up zsh"
	if should_run; then
		if which zsh >/dev/null 2>&1; then
			chsh -s "$(which zsh)" "$me"
		fi
	else
		dry_print "Would change default shell to zsh"
	fi
fi

